<script>
// ==================== STATE ====================
let canvas, ctx;
let elements = [];
let selectedElement = null;
let isDragging = false;
let dragOffset = { x: 0, y: 0 };
let zoom = 100;
let freeUses = 7;
let isPro = false;
let currentTemplate = 'gradient';

// ==================== INIT ====================
window.onload = function() {
    canvas = document.getElementById('main-canvas');
    ctx = canvas.getContext('2d');
    
    // Load saved uses
    const saved = localStorage.getItem('danishPosterUses');
    if (saved) {
        freeUses = parseInt(saved);
        updateFreeCounter();
    }
    
    // Setup events
    setupCanvasEvents();
    
    // Initial draw
    draw();
    
    console.log('Danish Poster loaded! Free uses:', freeUses);
};

// ==================== CANVAS EVENTS ====================
function setupCanvasEvents() {
    // Mouse
    canvas.addEventListener('mousedown', handleMouseDown);
    canvas.addEventListener('mousemove', handleMouseMove);
    canvas.addEventListener('mouseup', handleMouseUp);
    canvas.addEventListener('dblclick', handleDoubleClick);
    
    // Touch
    canvas.addEventListener('touchstart', handleTouchStart, { passive: false });
    canvas.addEventListener('touchmove', handleTouchMove, { passive: false });
    canvas.addEventListener('touchend', handleMouseUp);
}

// ==================== DRAWING ====================
function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    
    // Background
    drawBackground();
    
    // Elements
    elements.forEach(el => {
        ctx.save();
        if (el.type === 'text') drawText(el);
        else if (el.type === 'shape') drawShape(el);
        else if (el.type === 'image' && el.img) {
            ctx.drawImage(el.img, el.x, el.y, el.width, el.height);
        }
        ctx.restore();
    });
    
    // Selection indicator
    if (selectedElement) {
        drawSelectionBox();
    }
}

function drawBackground() {
    const w = canvas.width;
    const h = canvas.height;
    
    switch(currentTemplate) {
        case 'gradient':
            const g1 = ctx.createLinearGradient(0, 0, w, h);
            g1.addColorStop(0, '#667eea');
            g1.addColorStop(0.5, '#764ba2');
            g1.addColorStop(1, '#f093fb');
            ctx.fillStyle = g1;
            break;
        case 'dark':
            const g2 = ctx.createLinearGradient(0, 0, 0, h);
            g2.addColorStop(0, '#1a1a2e');
            g2.addColorStop(1, '#0f0f23');
            ctx.fillStyle = g2;
            break;
        case 'neon':
            const g3 = ctx.createLinearGradient(0, 0, w, h);
            g3.addColorStop(0, '#2d1b69');
            g3.addColorStop(1, '#0f0f23');
            ctx.fillStyle = g3;
            break;
        case 'minimal':
            ctx.fillStyle = '#ffffff';
            break;
        case 'pink':
            const g4 = ctx.createLinearGradient(0, 0, w, h);
            g4.addColorStop(0, '#f093fb');
            g4.addColorStop(1, '#f5576c');
            ctx.fillStyle = g4;
            break;
        case 'ocean':
            const g5 = ctx.createLinearGradient(0, 0, w, h);
            g5.addColorStop(0, '#4facfe');
            g5.addColorStop(1, '#00f2fe');
            ctx.fillStyle = g5;
            break;
        default:
            ctx.fillStyle = '#667eea';
    }
    
    ctx.fillRect(0, 0, w, h);
    
    // Decorative circles
    ctx.fillStyle = 'rgba(255,255,255,0.03)';
    ctx.beginPath();
    ctx.arc(w * 0.8, h * 0.2, w * 0.3, 0, Math.PI * 2);
    ctx.fill();
}

function drawText(el) {
    ctx.font = `${el.bold ? 'bold' : ''} ${el.size}px "${el.font}", sans-serif`;
    ctx.fillStyle = el.color;
    ctx.textAlign = 'left';
    ctx.textBaseline = 'top';
    
    // Effects
    if (el.effect === 'shadow') {
        ctx.shadowColor = 'rgba(0,0,0,0.4)';
        ctx.shadowBlur = 0;
        ctx.shadowOffsetX = 4;
        ctx.shadowOffsetY = 4;
    } else if (el.effect === 'neon') {
        ctx.shadowColor = el.color;
        ctx.shadowBlur = 20;
    }
    
    const lines = el.text.split('\n');
    lines.forEach((line, i) => {
        ctx.fillText(line, el.x, el.y + (i * el.size * 1.2));
    });
    
    // Measure
    let maxWidth = 0;
    lines.forEach(line => {
        const w = ctx.measureText(line).width;
        if (w > maxWidth) maxWidth = w;
    });
    el.width = maxWidth;
    el.height = lines.length * el.size * 1.2;
}

function drawShape(el) {
    ctx.fillStyle = el.color;
    
    switch(el.shape) {
        case 'square':
            ctx.fillRect(el.x, el.y, el.width, el.height);
            break;
        case 'circle':
            ctx.beginPath();
            ctx.arc(el.x + el.width/2, el.y + el.height/2, el.width/2, 0, Math.PI * 2);
            ctx.fill();
            break;
        case 'triangle':
            ctx.beginPath();
            ctx.moveTo(el.x + el.width/2, el.y);
            ctx.lineTo(el.x + el.width, el.y + el.height);
            ctx.lineTo(el.x, el.y + el.height);
            ctx.closePath();
            ctx.fill();
            break;
    }
}

function drawSelectionBox() {
    ctx.strokeStyle = '#7c3aed';
    ctx.lineWidth = 2;
    ctx.setLineDash([5, 5]);
    ctx.strokeRect(
        selectedElement.x - 5,
        selectedElement.y - 5,
        selectedElement.width + 10,
        selectedElement.height + 10
    );
    ctx.setLineDash([]);
}

// ==================== EVENT HANDLERS ====================
function handleMouseDown(e) {
    const rect = canvas.getBoundingClientRect();
    const scaleX = canvas.width / rect.width;
    const scaleY = canvas.height / rect.height;
    const x = (e.clientX - rect.left) * scaleX;
    const y = (e.clientY - rect.top) * scaleY;
    
    // Find clicked element (top to bottom)
    selectedElement = null;
    for (let i = elements.length - 1; i >= 0; i--) {
        const el = elements[i];
        if (x >= el.x && x <= el.x + el.width &&
            y >= el.y && y <= el.y + el.height) {
            selectedElement = el;
            isDragging = true;
            dragOffset.x = x - el.x;
            dragOffset.y = y - el.y;
            
            // Move to top
            elements.splice(i, 1);
            elements.push(selectedElement);
            break;
        }
    }
    
    updateProperties();
    updateLayers();
    draw();
}

function handleMouseMove(e) {
    if (!isDragging || !selectedElement) return;
    
    const rect = canvas.getBoundingClientRect();
    const scaleX = canvas.width / rect.width;
    const scaleY = canvas.height / rect.height;
    const x = (e.clientX - rect.left) * scaleX;
    const y = (e.clientY - rect.top) * scaleY;
    
    selectedElement.x = x - dragOffset.x;
    selectedElement.y = y - dragOffset.y;
    
    // Bounds
    selectedElement.x = Math.max(0, Math.min(canvas.width - selectedElement.width, selectedElement.x));
    selectedElement.y = Math.max(0, Math.min(canvas.height - selectedElement.height, selectedElement.y));
    
    draw();
}

function handleMouseUp() {
    isDragging = false;
}

function handleDoubleClick(e) {
    if (selectedElement && selectedElement.type === 'text') {
        const newText = prompt('Edit text:', selectedElement.text);
        if (newText !== null) {
            selectedElement.text = newText;
            draw();
            updateProperties();
            updateLayers();
        }
    }
}

function handleTouchStart(e) {
    e.preventDefault();
    const touch = e.touches[0];
    handleMouseDown({ clientX: touch.clientX, clientY: touch.clientY });
}

function handleTouchMove(e) {
    e.preventDefault();
    if (!isDragging) return;
    const touch = e.touches[0];
    handleMouseMove({ clientX: touch.clientX, clientY: touch.clientY });
}

// ==================== ADD ELEMENTS ====================
function addText() {
    const text = prompt('Enter your text:', 'Double click to edit');
    if (!text) return;
    
    const el = {
        id: Date.now(),
        type: 'text',
        text: text,
        x: canvas.width / 2 - 100,
        y: canvas.height / 2 - 30,
        width: 200,
        height: 60,
        size: 48,
        font: 'Montserrat',
        color: currentTemplate === 'minimal' ? '#000000' : '#ffffff',
        bold: true,
        effect: 'none'
    };
    
    elements.push(el);
    selectedElement = el;
    draw();
    updateProperties();
    updateLayers();
    showToast('Text added! Drag to move');
}

function addShape(shape) {
    const colors = ['#667eea', '#ec4899', '#10b981', '#f59e0b', '#ef4444'];
    const el = {
        id: Date.now(),
        type: 'shape',
        shape: shape,
        x: canvas.width/2 - 50,
        y: canvas.height/2 - 50,
        width: 100,
        height: 100,
        color: colors[Math.floor(Math.random() * colors.length)]
    };
    
    elements.push(el);
    selectedElement = el;
    draw();
    updateProperties();
    updateLayers();
}

function add3D(type) {
    if (!isPro) {
        showModal('pro-modal');
        return;
    }
    
    const emojis = { fire: '🔥', lightning: '⚡', crown: '👑', diamond: '💎', rocket: '🚀', trophy: '🏆' };
    const el = {
        id: Date.now(),
        type: 'text',
        text: emojis[type],
        x: canvas.width/2 - 40,
        y: canvas.height/2 - 40,
        width: 80,
        height: 80,
        size: 72,
        font: 'Segoe UI Emoji',
        color: '#ffffff',
        effect: 'none'
    };
    
    elements.push(el);
    selectedElement = el;
    draw();
    updateProperties();
    updateLayers();
}

function handleUpload(input) {
    const file = input.files[0];
    if (!file) return;
    
    const reader = new FileReader();
    reader.onload = function(e) {
        const img = new Image();
        img.onload = function() {
            const scale = Math.min(200 / img.width, 200 / img.height);
            const el = {
                id: Date.now(),
                type: 'image',
                img: img,
                x: canvas.width/2 - (img.width * scale)/2,
                y: canvas.height/2 - (img.height * scale)/2,
                width: img.width * scale,
                height: img.height * scale
            };
            elements.push(el);
            selectedElement = el;
            draw();
            updateProperties();
            updateLayers();
            showToast('Image uploaded!');
        };
        img.src = e.target.result;
    };
    reader.readAsDataURL(file);
}

// ==================== PROPERTIES PANEL ====================
function updateProperties() {
    const panel = document.getElementById('properties-panel');
    
    if (!selectedElement) {
        panel.innerHTML = `
            <div class="empty-state">
                <i class="fas fa-mouse-pointer text-4xl mb-4 opacity-50"></i>
                <div>Select an element to edit</div>
            </div>
        `;
        return;
    }
    
    const el = selectedElement;
    
    if (el.type === 'text') {
        panel.innerHTML = `
            <div class="property-group">
                <label class="property-label">Text</label>
                <textarea class="text-input" oninput="updateElementText(this.value)">${el.text}</textarea>
            </div>
            
            <div class="property-group">
                <label class="property-label">Font</label>
                <select class="font-select" onchange="updateElementFont(this.value)">
                    <option value="Montserrat" ${el.font === 'Montserrat' ? 'selected' : ''}>Montserrat</option>
                    <option value="Poppins" ${el.font === 'Poppins' ? 'selected' : ''}>Poppins</option>
                    <option value="Bebas Neue" ${el.font === 'Bebas Neue' ? 'selected' : ''}>Bebas Neue</option>
                    <option value="Playfair Display" ${el.font === 'Playfair Display' ? 'selected' : ''}>Playfair Display</option>
                    <option value="Oswald" ${el.font === 'Oswald' ? 'selected' : ''}>Oswald</option>
                </select>
            </div>
            
            <div class="property-group">
                <label class="property-label">Size</label>
                <div class="slider-control">
                    <input type="range" class="slider" min="12" max="120" value="${el.size}" oninput="updateElementSize(this.value)">
                    <span class="slider-value">${el.size}px</span>
                </div>
            </div>
            
            <div class="property-group">
                <label class="property-label">Color</label>
                <div class="color-row">
                    ${['#ffffff', '#000000', '#667eea', '#ec4899', '#10b981', '#f59e0b'].map(c => `
                        <div class="color-btn ${el.color === c ? 'active' : ''}" 
                             style="background: ${c}; ${c === '#000000' ? 'border: 1px solid #333' : ''}"
                             onclick="updateElementColor('${c}')"></div>
                    `).join('')}
                    <div class="color-custom">
                        <input type="color" value="${el.color}" onchange="updateElementColor(this.value)">
                    </div>
                </div>
            </div>
            
            <div class="property-group">
                <label class="property-label">Effect</label>
                <div class="effect-grid">
                    <div class="effect-btn ${el.effect === 'none' ? 'active' : ''}" onclick="updateElementEffect('none')">None</div>
                    <div class="effect-btn ${el.effect === 'shadow' ? 'active' : ''}" onclick="updateElementEffect('shadow')">Shadow</div>
                    <div class="effect-btn ${el.effect === 'neon' ? 'active' : ''}" onclick="updateElementEffect('neon')">Neon</div>
                    <div class="effect-btn ${el.effect === 'glow' ? 'active' : ''}" onclick="updateElementEffect('glow')">Glow</div>
                </div>
            </div>
            
            <button class="w-full py-2 bg-red-500/20 text-red-400 rounded-lg hover:bg-red-500/30 mt-4" onclick="deleteSelected()">
                <i class="fas fa-trash mr-2"></i> Delete
            </button>
        `;
    } else if (el.type === 'shape') {
        panel.innerHTML = `
            <div class="property-group">
                <label class="property-label">Color</label>
                <div class="color-row">
                    ${['#667eea', '#ec4899', '#10b981', '#f59e0b', '#ef4444'].map(c => `
                        <div class="color-btn ${el.color === c ? 'active' : ''}" 
                             style="background: ${c}"
                             onclick="updateElementColor('${c}')"></div>
                    `).join('')}
                </div>
            </div>
            <button class="w-full py-2 bg-red-500/20 text-red-400 rounded-lg hover:bg-red-500/30 mt-4" onclick="deleteSelected()">
                <i class="fas fa-trash mr-2"></i> Delete
            </button>
        `;
    } else if (el.type === 'image') {
        panel.innerHTML = `
            <div class="property-group">
                <label class="property-label">Size</label>
                <div class="slider-control">
                    <input type="range" class="slider" min="50" max="500" value="${el.width}" oninput="updateImageSize(this.value)">
                    <span class="slider-value">${Math.round(el.width)}px</span>
                </div>
            </div>
            <button class="w-full py-2 bg-red-500/20 text-red-400 rounded-lg hover:bg-red-500/30 mt-4" onclick="deleteSelected()">
                <i class="fas fa-trash mr-2"></i> Delete Image
            </button>
        `;
    }
}

function updateElementText(text) {
    if (selectedElement) {
        selectedElement.text = text;
        draw();
        updateLayers();
    }
}

function updateElementFont(font) {
    if (selectedElement) {
        selectedElement.font = font;
        draw();
    }
}

function updateElementSize(size) {
    if (selectedElement) {
        selectedElement.size = parseInt(size);
        event.target.nextElementSibling.textContent = size + 'px';
        draw();
    }
}

function updateElementColor(color) {
    if (selectedElement) {
        selectedElement.color = color;
        draw();
        updateProperties();
    }
}

function updateElementEffect(effect) {
    if (selectedElement) {
        selectedElement.effect = effect;
        draw();
        updateProperties();
    }
}

function updateImageSize(size) {
    if (selectedElement && selectedElement.type === 'image') {
        const ratio = selectedElement.height / selectedElement.width;
        selectedElement.width = parseInt(size);
        selectedElement.height = parseInt(size) * ratio;
        event.target.nextElementSibling.textContent = Math.round(size) + 'px';
        draw();
    }
}

function deleteSelected() {
    if (selectedElement) {
        elements = elements.filter(el => el !== selectedElement);
        selectedElement = null;
        draw();
        updateProperties();
        updateLayers();
    }
}

// ==================== LAYERS ====================
function updateLayers() {
    const list = document.getElementById('layers-list');
    
    if (elements.length === 0) {
        list.innerHTML = '<div class="empty-state" style="padding: 20px;"><div class="text-sm">No layers yet</div></div>';
        return;
    }
    
    list.innerHTML = elements.slice().reverse().map(el => `
        <div class="layer-item ${selectedElement === el ? 'active' : ''}" onclick="selectLayer(${el.id})">
            <div class="layer-icon">
                ${el.type === 'text' ? 'T' : el.type === 'image' ? '🖼️' : '⬜'}
            </div>
            <div class="layer-info">
                <div class="layer-name">${(el.text || el.type).substring(0, 20)}</div>
                <div class="layer-type">${el.type}</div>
            </div>
        </div>
    `).join('');
}

function selectLayer(id) {
    selectedElement = elements.find(el => el.id === id);
    draw();
    updateProperties();
    updateLayers();
}

// ==================== TEMPLATES & TOOLS ====================
function applyTemplate(template) {
    currentTemplate = template;
    
    if (template.startsWith('story')) {
        canvas.width = 450;
        canvas.height = 800;
    } else if (template === 'youtube') {
        canvas.width = 1280;
        canvas.height = 720;
    } else {
        canvas.width = 600;
        canvas.height = 600;
    }
    
    // Update text colors for minimal
    if (template === 'minimal') {
        elements.forEach(el => {
            if (el.type === 'text') el.color = '#000000';
        });
    }
    
    draw();
    showToast(template + ' template applied!');
}

function resizeCanvas(size) {
    const sizes = {
        instagram: [600, 600],
        story: [450, 800],
        youtube: [1280, 720]
    };
    
    if (size === 'story' && !isPro) {
        showModal('pro-modal');
        return;
    }
    
    const [w, h] = sizes[size];
    canvas.width = w;
    canvas.height = h;
    
    // Center elements
    elements.forEach(el => {
        el.x = w/2 - el.width/2;
        el.y = h/2 - el.height/2;
    });
    
    draw();
    showToast('Canvas resized');
}

function switchTab(tab, btn) {
    document.querySelectorAll('.sidebar-tab').forEach(t => t.classList.remove('active'));
    btn.classList.add('active');
    
    document.querySelectorAll('.sidebar-content').forEach(c => c.classList.add('hidden'));
    document.getElementById('tab-' + tab).classList.remove('hidden');
}

function setZoom(val) {
    zoom = val;
    canvas.style.transform = `scale(${val/100})`;
    document.getElementById('zoom-text').textContent = val + '%';
}

function adjustZoom(delta) {
    zoom = Math.max(50, Math.min(150, zoom + delta));
    setZoom(zoom);
}

// ==================== EXPORT - YEH SABSE IMPORTANT HAI ====================
function exportImage() {
    // Show modal with options
    document.getElementById('modal-free-count').textContent = freeUses;
    showModal('export-modal');
}

function downloadImage(quality) {
    if (freeUses <= 0 && !isPro) {
        closeModal('export-modal');
        showModal('pro-modal');
        return;
    }
    
    // Show loading
    const btn = event.currentTarget;
    const originalHTML = btn.innerHTML;
    btn.innerHTML = '<div class="loading"></div> Processing...';
    
    setTimeout(() => {
        try {
            // Create download link
            const link = document.createElement('a');
            
            // Generate filename
            const filename = `danish-poster-${Date.now()}.png`;
            
            // Get canvas data
            const dataURL = canvas.toDataURL('image/png', 1.0);
            
            // Set download attributes
            link.download = filename;
            link.href = dataURL;
            
            // Trigger download
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            
            // Update free uses
            if (!isPro) {
                freeUses--;
                localStorage.setItem('danishPosterUses', freeUses);
                updateFreeCounter();
            }
            
            // Close modal and show success
            closeModal('export-modal');
            showToast('✅ Image downloaded successfully!');
            
            console.log('Downloaded:', filename);
            
        } catch (error) {
            console.error('Download error:', error);
            showToast('❌ Error downloading. Try again.');
        }
        
        // Restore button
        btn.innerHTML = originalHTML;
        
    }, 500);
}

function checkProDownload(type) {
    if (!isPro) {
        closeModal('export-modal');
        showModal('pro-modal');
    } else {
        downloadImage(type);
    }
}

function updateFreeCounter() {
    document.getElementById('free-counter').textContent = freeUses;
    if (freeUses === 0 && !isPro) {
        document.getElementById('free-counter').classList.remove('text-green-400');
        document.getElementById('free-counter').classList.add('text-red-400');
    }
}

// ==================== MODALS ====================
function showModal(id) {
    document.getElementById(id).classList.add('active');
}

function closeModal(id) {
    document.getElementById(id).classList.remove('active');
}

function upgradeToPro() {
    isPro = true;
    closeModal('pro-modal');
    document.getElementById('free-counter').textContent = 'PRO';
    document.getElementById('free-counter').classList.remove('text-green-400', 'text-red-400');
    document.getElementById('free-counter').classList.add('text-yellow-400');
    showToast('🎉 Welcome to Pro!');
}

// ==================== UTILITIES ====================
function showToast(msg) {
    const toast = document.getElementById('toast');
    toast.textContent = msg;
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 3000);
}

function renameFile() {
